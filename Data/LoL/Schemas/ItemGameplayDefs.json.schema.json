{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Item gameplay definitions",
  "type": "object",
  "required": [
    "schemaVersion",
    "dataVersion",
    "items"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 0
    },
    "dataVersion": {
      "type": "integer",
      "minimum": 0
    },
    "sourcePatch": {
      "type": "string"
    },
    "sourceMapId": {
      "type": "integer",
      "minimum": 0
    },
    "buildHash": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "minItems": 1
    }
  }
}
