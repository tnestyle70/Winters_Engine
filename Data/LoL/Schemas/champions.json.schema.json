{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Champion gameplay authoring",
  "type": "object",
  "required": ["schemaVersion", "champions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "champions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/champion"}
    }
  },
  "$defs": {
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "positiveNumber": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "targetMode": {
      "type": "string",
      "enum": ["Self", "UnitTarget", "GroundTarget", "Direction"]
    },
    "rankValues": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {"$ref": "#/$defs/nonNegativeNumber"}
    },
    "scaleRange": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/nonNegativeNumber"}
    },
    "stage": {
      "type": "object",
      "required": [
        "targetMode",
        "lockDurationSec",
        "commandLockSec",
        "movePolicy"
      ],
      "additionalProperties": false,
      "properties": {
        "targetMode": {"$ref": "#/$defs/targetMode"},
        "facingMode": {
          "type": "string",
          "enum": ["None", "TowardsTarget", "TowardsCommandDirection"]
        },
        "lockDurationSec": {"$ref": "#/$defs/nonNegativeNumber"},
        "commandLockSec": {"$ref": "#/$defs/nonNegativeNumber"},
        "movePolicy": {
          "type": "string",
          "enum": [
            "Allow",
            "QueueUntilUnlock",
            "StationaryChannel",
            "ForcedMotion"
          ]
        },
        "createsActionState": {"type": "boolean", "default": true},
        "presentationLoopWhileActive": {"type": "boolean", "default": false}
      }
    },
    "charge": {
      "type": "object",
      "required": [
        "maxHoldSec",
        "autoRelease",
        "rangeScale",
        "damageScale",
        "stunSeconds"
      ],
      "additionalProperties": false,
      "properties": {
        "maxHoldSec": {"$ref": "#/$defs/positiveNumber"},
        "autoRelease": {"type": "boolean"},
        "rangeScale": {"$ref": "#/$defs/scaleRange"},
        "damageScale": {"$ref": "#/$defs/scaleRange"},
        "stunSeconds": {"$ref": "#/$defs/scaleRange"}
      }
    },
    "skill": {
      "type": "object",
      "required": [
        "slot",
        "targetMode",
        "stageCount",
        "stageWindowSec",
        "rangeMax",
        "skillId",
        "scalingTableId",
        "gameplayPolicyId",
        "visualCueId",
        "stages"
      ],
      "additionalProperties": false,
      "properties": {
        "slot": {"type": "integer", "minimum": 0, "maximum": 4},
        "targetMode": {"$ref": "#/$defs/targetMode"},
        "stageCount": {"type": "integer", "minimum": 1, "maximum": 2},
        "stageWindowSec": {"$ref": "#/$defs/nonNegativeNumber"},
        "cooldownSec": {"$ref": "#/$defs/nonNegativeNumber"},
        "cooldownSecByRank": {"$ref": "#/$defs/rankValues"},
        "rangeMax": {"$ref": "#/$defs/nonNegativeNumber"},
        "manaCost": {"$ref": "#/$defs/nonNegativeNumber"},
        "manaCostByRank": {"$ref": "#/$defs/rankValues"},
        "skillId": {"type": "integer", "minimum": 0},
        "scalingTableId": {"type": "integer", "minimum": 0},
        "gameplayPolicyId": {"type": "integer", "minimum": 0},
        "visualCueId": {"type": "integer", "minimum": 0},
        "activationMode": {
          "type": "string",
          "enum": ["Press", "PressRecast", "PressRelease"]
        },
        "charge": {"$ref": "#/$defs/charge"},
        "stages": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {"$ref": "#/$defs/stage"}
        }
      },
      "allOf": [
        {
          "anyOf": [
            {"required": ["cooldownSec"]},
            {"required": ["cooldownSecByRank"]}
          ]
        },
        {
          "anyOf": [
            {"required": ["manaCost"]},
            {"required": ["manaCostByRank"]}
          ]
        },
        {
          "if": {"properties": {"stageCount": {"const": 1}}},
          "then": {
            "properties": {
              "stageWindowSec": {"const": 0},
              "stages": {"minItems": 1, "maxItems": 1}
            }
          }
        },
        {
          "if": {"properties": {"stageCount": {"const": 2}}},
          "then": {
            "required": ["activationMode"],
            "properties": {
              "stageWindowSec": {"exclusiveMinimum": 0},
              "activationMode": {"enum": ["PressRecast", "PressRelease"]},
              "stages": {"minItems": 2, "maxItems": 2}
            }
          }
        },
        {
          "if": {
            "required": ["activationMode"],
            "properties": {"activationMode": {"const": "PressRelease"}}
          },
          "then": {"required": ["charge"]}
        },
        {
          "if": {"required": ["charge"]},
          "then": {
            "required": ["activationMode"],
            "properties": {"activationMode": {"const": "PressRelease"}}
          }
        }
      ]
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseHp", "hpPerLevel", "baseMana", "manaPerLevel", "resourceKind", "resourceRegenPerSec",
        "baseAd", "adPerLevel", "baseAp", "apPerLevel",
        "baseArmor", "armorPerLevel", "baseMr", "mrPerLevel",
        "baseAttackSpeed", "attackSpeedRatio", "attackSpeedPerLevel", "basicAttackWindupSec",
        "baseAttackRange", "baseMoveSpeed", "navArriveRadius",
        "spatialRadius", "sightRange"
      ],
      "properties": {
        "baseHp": {"$ref": "#/$defs/nonNegativeNumber"},
        "hpPerLevel": {"$ref": "#/$defs/nonNegativeNumber"},
        "baseMana": {"$ref": "#/$defs/nonNegativeNumber"},
        "manaPerLevel": {"$ref": "#/$defs/nonNegativeNumber"},
        "resourceKind": {"enum": ["Mana", "Energy", "None", "Flow"]},
        "resourceRegenPerSec": {"$ref": "#/$defs/nonNegativeNumber"},
        "baseAd": {"$ref": "#/$defs/nonNegativeNumber"},
        "adPerLevel": {"type": "number"},
        "baseAp": {"type": "number"},
        "apPerLevel": {"type": "number"},
        "baseArmor": {"$ref": "#/$defs/nonNegativeNumber"},
        "armorPerLevel": {"type": "number"},
        "baseMr": {"$ref": "#/$defs/nonNegativeNumber"},
        "mrPerLevel": {"type": "number"},
        "baseAttackSpeed": {"$ref": "#/$defs/nonNegativeNumber"},
        "attackSpeedRatio": {"$ref": "#/$defs/nonNegativeNumber"},
        "attackSpeedPerLevel": {"type": "number"},
        "basicAttackWindupSec": {"$ref": "#/$defs/nonNegativeNumber"},
        "baseAttackRange": {"$ref": "#/$defs/nonNegativeNumber"},
        "baseMoveSpeed": {"$ref": "#/$defs/nonNegativeNumber"},
        "navArriveRadius": {"$ref": "#/$defs/nonNegativeNumber"},
        "spatialRadius": {"$ref": "#/$defs/nonNegativeNumber"},
        "sightRange": {"$ref": "#/$defs/nonNegativeNumber"}
      }
    },
    "passiveDash": {
      "type": "object",
      "required": ["distance", "durationSec", "inputGraceSec"],
      "additionalProperties": false,
      "properties": {
        "distance": {"$ref": "#/$defs/nonNegativeNumber"},
        "durationSec": {"$ref": "#/$defs/nonNegativeNumber"},
        "inputGraceSec": {"$ref": "#/$defs/nonNegativeNumber"}
      }
    },
    "passiveSoul": {
      "type": "object",
      "required": ["lifetimeSec", "radius"],
      "additionalProperties": false,
      "properties": {
        "lifetimeSec": {"$ref": "#/$defs/positiveNumber"},
        "radius": {"$ref": "#/$defs/positiveNumber"}
      }
    },
    "champion": {
      "type": "object",
      "required": ["champion", "dataVersion", "stats", "skills"],
      "additionalProperties": false,
      "properties": {
        "champion": {"type": "string", "minLength": 1},
        "dataVersion": {"type": "integer", "minimum": 1},
        "stats": {"$ref": "#/$defs/stats"},
        "skills": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {"$ref": "#/$defs/skill"}
        },
        "passiveDash": {"$ref": "#/$defs/passiveDash"},
        "passiveSoul": {"$ref": "#/$defs/passiveSoul"}
      }
    }
  }
}
