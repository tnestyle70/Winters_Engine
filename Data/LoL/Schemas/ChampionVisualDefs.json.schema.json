{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Champion timing visual definitions",
  "type": "object",
  "required": [
    "schemaVersion",
    "champions"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 0
    },
    "champions": {
      "type": "array",
      "minItems": 1
    }
  }
}
