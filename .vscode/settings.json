{
  "files.associations": {
    "*.md": "markdown"
  },
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },
  "[markdown]": {
    "editor.fontFamily": "'D2Coding', 'Cascadia Code', Consolas, 'Malgun Gothic', monospace",
    "editor.fontSize": 15,
    "editor.lineHeight": 24,
    "editor.wordWrap": "on",
    "editor.renderWhitespace": "selection",
    "editor.semanticHighlighting.enabled": true
  },
  "markdown.preview.fontFamily": "Pretendard, 'Segoe UI', 'Malgun Gothic', system-ui, sans-serif",
  "markdown.preview.fontSize": 15,
  "markdown.preview.lineHeight": 1.65,
  "markdown.preview.breaks": false,
  "markdown.preview.scrollPreviewWithEditor": true,
  "markdown.preview.scrollEditorWithPreview": true,
  "markdown.styles": [
    ".vscode/markdown-preview.css"
  ],
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "markup.heading.markdown"
        ],
        "settings": {
          "foreground": "#93C5FD",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.inline.raw.string.markdown"
        ],
        "settings": {
          "foreground": "#BFDBFE"
        }
      },
      {
        "scope": [
          "markup.bold.markdown"
        ],
        "settings": {
          "foreground": "#F9FAFB",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.italic.markdown"
        ],
        "settings": {
          "foreground": "#D8B4FE",
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "punctuation.definition.list.begin.markdown"
        ],
        "settings": {
          "foreground": "#60A5FA"
        }
      }
    ]
  }
}
